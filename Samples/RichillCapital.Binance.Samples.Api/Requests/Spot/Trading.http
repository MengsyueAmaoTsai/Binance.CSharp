@Localhost = https://localhost:20000

### New order
POST {{Localhost}}/api/spot/orders
Content-Type: application/json

{
    "symbol": "BTCUSDT",
    "side": "BUY",
    "type": "MARKET",
    "quantity": 1
}


### Test new order
POST {{Localhost}}/api/spot/orders/test
Content-Type: application/json

{
    "symbol": "BTCUSDT",
    "side": "BUY",
    "type": "MARKET",
    "quantity": 1
}

